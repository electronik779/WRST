<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:WRST.maui"
             x:Class="WRST.maui.MainPage"
             Title="ВЭР годичного регулирования">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Открыть" Clicked="Open_Click" IconImageSource="open_icon.png" />
        <ToolbarItem Text="Сохранить" Clicked="Save_Click" IconImageSource="save_icon.png" />
        <ToolbarItem Text="Выполнить" Clicked="Execute_Click" IconImageSource="execute_icon.png" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="10">

            <Grid ColumnDefinitions="*, 240, 120" RowDefinitions=
                  "Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto" 
                  RowSpacing="10">

                <Label Grid.Row="0" Grid.Column="0" Text="Номер календарного месяца начала расчета" VerticalOptions="Center"/>
                <Entry Grid.Row="0" Grid.Column="1" x:Name="BeginningMonth" TextChanged="BeginningMonth_TextChanged" Keyboard="Numeric"/>

                <Label Grid.Row="1" Grid.Column="0" Text="Количество значений притока" VerticalOptions="Center"/>
                <Entry Grid.Row="1" Grid.Column="1" x:Name="InflowCount" TextChanged="InflowCountInput_TextChanged" Keyboard="Numeric"/>
                <Button Grid.Row="1" Grid.Column="2" Text="Создать" Margin="10,0,0,0" Clicked="InflowButton_Clicked" />

                <VerticalStackLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Padding="10" Spacing="20">
                    <!-- Контейнер для Таблицы 1 -->
                    <Grid ColumnDefinitions="100, *" VerticalOptions="Start">
                        <!-- Фиксированный столбец (ID / Названия строк) -->
                        <Grid x:Name="FixedColumn1" 
                            Grid.Column = "0"
                            BackgroundColor="LightGray"
                            VerticalOptions="Start"/>

                        <!-- Прокручиваемая часть (Данные) -->
                        <!-- Убираем FillAndExpand, используем Grid.Column="1" -->
                        <ScrollView Grid.Column="1" 
                            Orientation="Horizontal" 
                            VerticalOptions="Start"
                            HorizontalScrollBarVisibility="Always">
                            <Grid x:Name="ScrollableGrid1" 
                                HorizontalOptions="Start" />
                        </ScrollView>
                    </Grid>
                </VerticalStackLayout>

                <Label Grid.Row="3" Grid.Column="0" Text="Полезный объем водохранилища, млн.м³" VerticalOptions="Center"/>
                <Entry Grid.Row="3" Grid.Column="1" x:Name="UsefullVolume" Keyboard="Numeric"/>

                <Label Grid.Row="4" Grid.Column="0" Text="Мёртвый объем водохранилища, млн.м³" VerticalOptions="Center"/>
                <Entry Grid.Row="4" Grid.Column="1" x:Name="UselessVolume" Keyboard="Numeric"/>

                <Label Grid.Row="5" Grid.Column="0" Text="Количество точек батиграфической характеристики" VerticalOptions="Center"/>
                <Entry Grid.Row="5" Grid.Column="1" x:Name="BathygraphicCount" TextChanged="BathygraphicCountInput_TextChanged" Keyboard="Numeric"/>
                <Button Grid.Row="5" Grid.Column="2" Text="Создать" Margin="10,0,0,0" Clicked="BathygraphicButton_Clicked" />
                <VerticalStackLayout Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3" Padding="10" Spacing="20">
                    <Grid ColumnDefinitions="100, *" VerticalOptions="Start">
                        <Grid x:Name="FixedColumn2" 
                            Grid.Column = "0"
                            BackgroundColor="LightGray"
                            VerticalOptions="Start"/>

                        <ScrollView Grid.Column="1" 
                            Orientation="Horizontal" 
                            VerticalOptions="Start"
                            HorizontalScrollBarVisibility="Always">
                            <Grid x:Name="ScrollableGrid2" 
                                HorizontalOptions="Start" />
                        </ScrollView>
                    </Grid>
                </VerticalStackLayout>

                <Label Grid.Row="7" Grid.Column="0" Text="Диспетчерские остатки на конец месяца" VerticalOptions="Center"/>
                <VerticalStackLayout Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="3" Padding="10" Spacing="20">
                    <Grid ColumnDefinitions="100, *" VerticalOptions="Start">
                        <Grid x:Name="FixedColumn3" 
                            Grid.Column = "0"
                            BackgroundColor="LightGray"
                            VerticalOptions="Start"/>

                        <ScrollView Grid.Column="1" 
                            Orientation="Horizontal" 
                            VerticalOptions="Start"
                            HorizontalScrollBarVisibility="Always">
                            <Grid x:Name="ScrollableGrid3" 
                                HorizontalOptions="Start" />
                        </ScrollView>
                    </Grid>
                </VerticalStackLayout>

                <Label Grid.Row="9" Grid.Column="0" Text="Отбор из водохранилища" VerticalOptions="Center"/>
                <VerticalStackLayout Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="3" Padding="10" Spacing="20">
                    <Grid ColumnDefinitions="100, *" VerticalOptions="Start">
                        <Grid x:Name="FixedColumn4" 
                            Grid.Column = "0"
                            BackgroundColor="LightGray"
                            VerticalOptions="Start"/>

                        <ScrollView Grid.Column="1" 
                            Orientation="Horizontal" 
                            VerticalOptions="Start"
                            HorizontalScrollBarVisibility="Always">
                            <Grid x:Name="ScrollableGrid4" 
                                HorizontalOptions="Start" />
                        </ScrollView>
                    </Grid>
                </VerticalStackLayout>

                <Label Grid.Row="11" Grid.Column="0" Text="Количество точек характеристики нижнего бьефа" VerticalOptions="Center"/>
                <Entry Grid.Row="11" Grid.Column="1" x:Name="CharacteristicOfDownstreamCount" TextChanged="CharacteristicOfDownstreamCountInput_TextChanged" Keyboard="Numeric"/>
                <Button Grid.Row="11" Grid.Column="2" Text="Создать" Margin="10,0,0,0" Clicked="CharacteristicOfDownstreamButton_Clicked" />
                <VerticalStackLayout Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="3" Padding="10" Spacing="20">
                    <Grid ColumnDefinitions="100, *" VerticalOptions="Start">
                        <Grid x:Name="FixedColumn5" 
                            Grid.Column = "0"
                            BackgroundColor="LightGray"
                            VerticalOptions="Start"/>

                        <ScrollView Grid.Column="1" 
                            Orientation="Horizontal" 
                            VerticalOptions="Start"
                            HorizontalScrollBarVisibility="Always">
                            <Grid x:Name="ScrollableGrid5" 
                                HorizontalOptions="Start" />
                        </ScrollView>
                    </Grid>
                </VerticalStackLayout>

                <Label Grid.Row="13" Grid.Column="0" Text="Схема питания ГЭС" VerticalOptions="Center"/>
                <VerticalStackLayout Grid.Row="13" Grid.Column="1" RadioButtonGroup.SelectedValue="{Binding SelectedOption}">
                    <RadioButton Content="индивидуальная" Value="o" IsChecked="True" />
                    <RadioButton Content="групповая"      Value="g"/>
                </VerticalStackLayout>

                <Label Grid.Row="14" Grid.Column="0" Text="Гарантированный расход ГЭС, м³/с" VerticalOptions="Center"/>
                <Entry Grid.Row="14" Grid.Column="1" x:Name="GuaranteedDischarge" Keyboard="Numeric"/>

                <Label Grid.Row="15" Grid.Column="0" Text="Полный (максимальный) расход ГЭС, м³/с" VerticalOptions="Center"/>
                <Entry Grid.Row="15" Grid.Column="1" x:Name="FullDischarge" Keyboard="Numeric"/>

                <Label Grid.Row="16" Grid.Column="0" Text="Потери напора, м" VerticalOptions="Center"/>
                <Entry Grid.Row="16" Grid.Column="1" x:Name="HeadLoss" Keyboard="Numeric"/>

                <Label Grid.Row="17" Grid.Column="0" Text="Кпд гидроагрегата" VerticalOptions="Center"/>
                <Entry Grid.Row="17" Grid.Column="1" x:Name="Efficiency" Keyboard="Numeric"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
